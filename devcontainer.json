{
  // Name shown in the Codespaces "Creating codespace" UI and VS Code status bar.
  "name": "Drupal (CSS/theme sandbox)",

  // Build our own image instead of pulling a generic one, so PHP + Composer +
  // Drush versions are pinned and identical for every contributor/project.
  "build": {
    "dockerfile": "Dockerfile"
  },

  // Add Node.js via a prebuilt Devcontainer "feature" rather than baking it into
  // the Dockerfile by hand. This is the officially maintained way to get Node,
  // and it's easy to bump the version below without touching the Dockerfile.
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20" // LTS. Bump here when a project's theme needs a newer Node.
    }
  },

  // Drupal will be served by PHP's built-in webserver on 8080 (see setup.sh).
  // forwardPorts + portsAttributes makes Codespaces auto-open/label it.
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Drupal site",
      "onAutoForward": "openPreview"
    }
  },

  // Runs once, the first time the Codespace is created (not on every restart).
  // This is where we install Drupal and print the login credentials.
  "postCreateCommand": "bash .devcontainer/setup.sh",

  // Runs every time the Codespace is (re)attached/started, including after a
  // rebuild or a resume from sleep. Starts the PHP server in the background.
  "postStartCommand": "bash .devcontainer/start-server.sh",

  // Nice-to-haves for a non-dev editing CSS/Twig in the VS Code UI.
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client", // PHP intellisense
        "recca0120.vscode-phpunit",
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode"
      ]
    }
  },

  // Codespace runs as the default non-root "vscode" user.
  "remoteUser": "vscode"
}
